# =====================================================================
# MyBudget — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# =====================================================================

# Supabase (Project Settings → API)
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Sentry (sentry.io → Project → DSN)
REACT_APP_SENTRY_DSN=https://YOUR_KEY@sentry.io/PROJECT_ID

# PostHog (posthog.com → Project → API Key)
REACT_APP_POSTHOG_KEY=phc_your_posthog_key_here

# Stripe (stripe.com → Developers → API keys → Publishable key)
REACT_APP_STRIPE_PUBLIC_KEY=pk_live_your_stripe_key_here
